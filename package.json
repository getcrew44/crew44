{
  "name": "crew44",
  "productName": "Crew44",
  "version": "0.5.0",
  "main": "electron/main.cjs",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "mkdir -p bin && cd daemon && go build -o ../bin/crew44-daemon ./cmd/crew44-daemon && cd .. && node electron/scripts/dev.cjs",
    "build": "mkdir -p bin && cd daemon && go build -o ../bin/crew44-daemon ./cmd/crew44-daemon && cd .. && vite build && node electron/scripts/build.cjs",
    "web:dev": "node daemon/scripts/web-dev.cjs",
    "mobile:start": "npm --workspace=@crew44/mobile run start --",
    "mobile:android": "npm --workspace=@crew44/mobile run android --",
    "mobile:ios": "npm --workspace=@crew44/mobile run ios --",
    "test:mobile": "npm --workspace=@crew44/mobile run test",
    "test": "cd daemon && go test ./... && cd .. && vitest run && npm run test:mobile",
    "clean": "rm -rf bin dist .electron-app crew44-server crew44-daemon"
  },
  "dependencies": {
    "qrcode.react": "^4.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.0.1",
    "jsdom": "^29.1.1",
    "vite": "^6.3.2",
    "vitest": "^4.1.6"
  }
}
