    "expo-crypto": "^15.0.8",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.13",
    "expo-secure-store": "~15.0.7",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
