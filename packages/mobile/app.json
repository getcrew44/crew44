{
  "expo": {
    "name": "Crew44 Mobile",
    "slug": "crew44-mobile",
    "scheme": "crew44-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Crew44 Mobile to scan pairing QR codes."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mindive.crew44",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mindive.crew44",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dc150a5d-bc16-480d-bb1f-3d5c1fd6016a"
      }
    },
    "owner": "mindivelabs"
  }
}
